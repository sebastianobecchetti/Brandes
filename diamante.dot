graph diamante {
  layout=neato;
  node [shape=circle, style=filled, fillcolor="#cfe8ff",
        fontname="Helvetica", width=0.45, fixedsize=true];
  edge [penwidth=1.2];

  0 [pos="0,0!", fillcolor="#ffd5d5"];   // sorgente s = 0
  1 [pos="1.1,0.9!"];
  2 [pos="1.1,-0.9!"];
  3 [pos="2.2,0!"];
  4 [pos="3.3,0!"];

  0 -- 1;
  0 -- 2;
  1 -- 3;
  2 -- 3;
  3 -- 4;
}
